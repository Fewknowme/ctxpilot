{
  "name": "ctxpilot",
  "version": "0.1.0",
  "description": "Auto-builds and injects project context into every AI tool you use",
  "type": "module",
  "bin": {
    "ctxpilot": "dist/index.js",
    "ctx": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@anthropic-ai/sdk": "^0.31.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@ctxpilot/mcp-server": "0.1.0",
    "chokidar": "^4.0.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "openai": "^6.27.0",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.2",
    "vitest": "^2.1.1"
  }
}
