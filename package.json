{
  "name": "ctxpilot",
  "version": "0.1.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "postbuild": "cp README.md packages/cli/README.md && cp README.md packages/mcp-server/README.md",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "turbo": "^2.1.1",
    "typescript": "^5.9.2"
  }
}
