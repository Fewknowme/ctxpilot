# Copy this file to `.env` in the root of the project where you run `contextkeeper`.
# Example:
#   /path/to/your-project/.env
#
# Optional global location:
#   ~/.ck/.env
# The project-level `.env` wins over the global file.

# Provider: anthropic | openai
CK_PROVIDER=anthropic

# Anthropic
CK_API_KEY=your_anthropic_key_here

# OpenAI
# CK_PROVIDER=openai
# CK_OPENAI_API_KEY=your_openai_key_here

# Optional model override
# CK_MODEL=claude-sonnet-4-20250514
